# ============================================================
# KI-Trainer 2026 — Konfiguration
# Kopiere diese Datei nach .env und trage deine Werte ein.
# ============================================================

# -------------------------------------------------------
# LLM-Backend (LiteLLM-Gateway)
# -------------------------------------------------------
OPENAI_API_KEY=dein-litellm-api-key
OPENAI_BASE_URL=http://dein-litellm-server/v1

# Modell für Chat (z.B. gpt-4o-mini oder ein lokales Modell via LiteLLM)
LLM_MODEL=gpt-4o-mini

# Modell für Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# -------------------------------------------------------
# ChromaDB
# -------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=wm2026

# -------------------------------------------------------
# Qdrant (optional)
# -------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=wm2026

# -------------------------------------------------------
# MCP-Server
# -------------------------------------------------------
MCP_SERVER_URL=http://localhost:9000
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=9000

# -------------------------------------------------------
# Datenpipeline
# -------------------------------------------------------
# Auf 'true' setzen, um gecachte Daten zu verwenden (schneller)
USE_CACHED_DATA=true
